# --- Core ---
PAYLOAD_SECRET=<generate-with-openssl-rand-hex-24>
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Database ---
# Local development uses SQLite (zero setup). For production, set POSTGRES_URL
# to the Neon connection string — the app switches to Postgres automatically.
DATABASE_URI=file:./curatone.db
# POSTGRES_URL=postgresql://user:password@ep-xxx.neon.tech/curatone?sslmode=require

# --- File storage (Cloudflare R2 / S3-compatible) ---
# Leave empty for local disk storage (development). Fill in for production.
# S3_BUCKET=curatone
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto

# --- Stripe (competition fees, certificates) ---
# Leave empty to disable payments (free entry still works).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
